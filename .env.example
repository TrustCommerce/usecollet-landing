# Waitlist API endpoint (Spring Boot WaitlistApi — POST /v1/waitlist).
# Defaults to the production API when unset.
NEXT_PUBLIC_WAITLIST_API=https://api.usecollet.com/usecollet-api/v1/waitlist

# For local development against a backend running on :8081, use:
# NEXT_PUBLIC_WAITLIST_API=http://localhost:8081/usecollet-api/v1/waitlist
